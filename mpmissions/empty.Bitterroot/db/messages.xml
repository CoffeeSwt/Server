<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<messages>
	<message>
        <deadline>240</deadline>
        <shutdown>1</shutdown>
        <text>服务器将在 #tmin 分钟后关闭重启，请提前下线避免物资丢失</text>
    </message>
	<message>
        <delay>2</delay>
        <onconnect>1</onconnect>
        <text>服务器严禁拆家，严禁开挂，严禁私自拉人，遇到问题请在群里联系管理员</text>
    </message>
	<message>
        <repeat>15</repeat>
        <text>服务器严禁拆家，严禁开挂，严禁私自拉人，遇到问题请在群里联系管理员</text>
    </message>
